# ======================================================================
# WHATSAPP BUSINESS MESSAGING SYSTEM - ENVIRONMENT CONFIGURATION
# ======================================================================

# ── META WHATSAPP BUSINESS API (Official API) ─────────────────────────────
# Get these from: https://developers.facebook.com/apps/
WHATSAPP_ACCESS_TOKEN=EAAJZCJ...your_permanent_access_token_here
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_VERIFY_TOKEN=my_secret_webhook_token_12345
WHATSAPP_WEBHOOK_URL=https://your-domain.com/webhook
WHATSAPP_API_VERSION=v18.0

# ── WHATSAPP INTEGRATION SETTINGS ────────────────────────────────────────
# Set to True to use real WhatsApp API, False for simulation mode
USE_REAL_WHATSAPP=False

# ── GOOGLE CLOUD APIS ───────────────────────────────────────────────────────
# Download service account JSON from: https://console.cloud.google.com/
GOOGLE_CREDS_FILE=google_credentials.json
GOOGLE_SHEET_NAME=WhatsApp_Messages
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# ── DATABASE CONFIGURATION ───────────────────────────────────────────────────
DATABASE_URL=sqlite:///automated_messaging.db
REDIS_URL=redis://localhost:6379/0

# ── FLASK APPLICATION ────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_PORT=5000
FLASK_HOST=0.0.0.0
SECRET_KEY=your_secret_key_here

# ── BUSINESS CONFIGURATION ──────────────────────────────────────────────────
BUSINESS_PHONE=+8861655542
BUSINESS_NAME=Your Business Name
BUSINESS_EMAIL=business@yourdomain.com

# ── AUTOMATION SETTINGS ────────────────────────────────────────────────────
AUTO_SEND_ENABLED=True
INCOMING_CHECK_INTERVAL=30
MESSAGE_DELAY_MIN=3
MESSAGE_DELAY_MAX=8
CAMPAIGN_BATCH_SIZE=50

# ── LOGGING CONFIGURATION ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/automated_messaging.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5

# ── RATE LIMITING ──────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000

# ── WEBHOOK CONFIGURATION ───────────────────────────────────────────────────
WEBHOOK_SECRET=your_webhook_secret_here
WEBHOOK_TIMEOUT=30

# ── MESSAGE TEMPLATES ────────────────────────────────────────────────────────
WELCOME_MESSAGE=Hello! Welcome to {business_name}. How can we help you today?
PROMOTION_MESSAGE=Special offer! Get {discount}% off on {product}. Limited time only!
SUPPORT_MESSAGE=Thank you for contacting support. We'll get back to you within 24 hours.

# ── TESTING CONFIGURATION ───────────────────────────────────────────────────
TEST_MODE=False
TEST_PHONE_NUMBER=+1234567890
SIMULATION_SUCCESS_RATE=95
